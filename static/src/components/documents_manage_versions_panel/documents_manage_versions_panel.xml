<?xml version="1.0" encoding="UTF-8" ?>
<templates>
  <t t-name="documents.ManageVersions" t-inherit="documents.ManageVersions" t-inherit-mode="extension">
    <xpath expr="//button[@t-on-click='() => this.onDownload(version.id)']" position="before">
      <button type="button" class="btn btn-secondary mx-1" t-on-click="() => this.onOpenInEuroOffice(version.id)">
        <i class="fa fa-external-link me-1" />Open </button>
    </xpath>
  </t>
</templates>
