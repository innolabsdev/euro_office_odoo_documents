<?xml version="1.0" encoding="UTF-8" ?>
<templates>
  <t t-name="euro_office_odoo_documents.EuroOfficeIcon">
    <img src="/euro_office_odoo/static/svg/euro_office_logo.svg" alt="Euro-Office" style="height: 14px;" class="euro_office-icon"/>
  </t>
  <t
    t-name="euro_office_odoo_documents.DocumentsViews.Buttons"
    t-inherit="documents.DocumentsViews.ControlPanel"
    t-inherit-mode="extension"
  >
    <xpath expr="//DropdownItem[@onSelected='onClickDocumentsAddUrl']" position="after">
      <DropdownItem
        tag="'button'"
        class="'btn btn-link o_documents_kanban_euro_office_odoo_documents'"
        t-if="userIsInternal"
        onSelected="() => this.onClickCreateEuroOffice()"
        attrs="{disabled: !canUploadInFolder(folder)}"
      >
        <i class="me-2">
          <t t-call="euro_office_odoo_documents.EuroOfficeIcon" />
        </i>
        <span>Create with Euro-Office</span>
      </DropdownItem>
    </xpath>
  </t>
</templates>
