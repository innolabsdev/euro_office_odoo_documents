<?xml version="1.0" encoding="utf-8" ?>
<odoo>
  <template id="euro_office_odoo_documents.share_file" inherit_id="documents.share_file">
    <xpath expr="//div[hasclass('mt16') and hasclass('mb8')]/a" position="inside">
      <a
        t-if="euro_office_supported"
        class="btn btn-secondary rounded-pill mt-2"
        t-att-href="'/euro_office/documents/share/' + document.access_token"
        target="_blank"
      >
        <img
        class="mb-1"
        src="/euro_office_odoo_documents/static/svg/edit_black.svg"
        role="img"
      /> Open in Euro-Office </a>
    </xpath>
  </template>

  <template id="euro_office_odoo_documents.public_folder_page" inherit_id="documents.public_folder_page">
    <!-- For binary files -->
    <xpath expr="//article[@id='documents-binary']//div[hasclass('o_card_right')]" position="before">
      <t t-set="current_doc_id" t-value="str(document.id)" />
      <t t-set="is_supported" t-value="False" />

      <t t-foreach="euro_office_supported" t-as="supported_doc">
        <t t-if="str(supported_doc['document'].id) == current_doc_id and
    supported_doc['euro_office_supported']">
          <t t-set="is_supported" t-value="True" />
        </t>
      </t>

      <t t-if="is_supported">
        <div class="o_card_right d-flex flex-column flex-nowrap justify-content-end text-end me-1">
          <a
            t-att-href="'/euro_office/documents/share/' + document.access_token"
            title="Open in Euro-Office"
            target="_blank"
          >
            <img class="mb-1" src="/euro_office_odoo_documents/static/svg/edit_black.svg" role="img" />
          </a>
        </div>
      </t>
    </xpath>
  </template>
</odoo>
